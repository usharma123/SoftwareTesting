{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "preserveSymlinks": true,
    "types": []
  },
  "include": ["deepsec.config.ts", "matchers/**/*.ts"]
}
